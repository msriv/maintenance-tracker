<?xml version="1.0" encoding="utf-8"?>
<!--
    We exclude backup of sensitive data. The user manages their own data locally.
    Room database files are excluded to prevent accidental cloud sync of personal data.
-->
<full-backup-content>
    <exclude domain="database" path="." />
    <exclude domain="sharedpref" path="." />
    <exclude domain="file" path="." />
</full-backup-content>
