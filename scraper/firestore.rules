rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Public registry — readable by all clients.
    // Writes are only allowed via the Admin SDK (service account) used by the scraper.
    match /registry_makes/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /registry_models/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /registry_schedules/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    match /best_practices/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Recall alerts — publicly readable, scraper-only writes.
    match /recalls/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Sync metadata — publicly readable so the app can surface "last updated" info.
    match /sync_metadata/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // User backups — each device (identified by its anonymous Firebase Auth UID)
    // can read and write only its own backup subtree.
    match /backups/{deviceId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == deviceId;
    }
  }
}
